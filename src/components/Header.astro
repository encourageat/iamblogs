---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>

    <h2>
      <a href="/">EncourageAt Blog</a>
    </h2>

    <div class="menu">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>

      <a
        href="https://encourageat.com"
        target="_blank"
        rel="noopener noreferrer"
        class="home-link"
        title="Go to EncourageAt"
      >
        <img src="/images/home.svg" alt="Home" />
      </a>

    </div>

  </nav>
</header>
<style>
header {
        background: rgba(255,255,255,.95);
    box-shadow: 0 2px 8px rgba(var(--black),0.05);
}

nav {

    max-width: 980px;

    margin: auto;

    display: flex;

    justify-content: center;

    align-items: center;

    gap: 2rem;

    padding: .9rem 1rem;
}

h2{
    margin:0;
    font-size:1.7rem;
}

h2 a{

    color:#163a96;

    text-decoration:none;

    font-weight:700;
}

.menu{

    display:flex;

    align-items:center;

    gap:1.3rem;
}

.menu a{

    color:#222;

    text-decoration:none;

    font-size:1rem;
}

.home-link img{

    width:22px;

    height:22px;
}
@media (max-width:720px){

    nav{

        gap:.9rem;

        padding:.8rem;
    }

    h2{

        font-size:1.2rem;
    }

    .menu{

        gap:.7rem;
    }

    .menu a{

        font-size:.9rem;
    }

    .home-link img{

        width:18px;

        height:18px;
    }

}
</style>
